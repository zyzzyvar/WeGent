# Public service URL, for menus/H5 links.
PUBLIC_BASE_URL=https://your-domain.example

# WeChat Official Account callback token and app credentials.
WECHAT_TOKEN=change-me
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Keep this true in real deployments. For local callback smoke tests only.
WECHAT_VERIFY_SIGNATURE=true

# Local OpenAI-compatible LLM endpoint.
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=

# Runtime data.
DATA_DIR=./data
TIMEZONE=Asia/Shanghai

