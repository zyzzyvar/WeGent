# Public service URL, for menus/H5 links.
PUBLIC_BASE_URL=https://your-domain.example

# WeChat Official Account callback token and app credentials.
WECHAT_TOKEN=change-me
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Keep this true in real deployments. For local callback smoke tests only.
WECHAT_VERIFY_SIGNATURE=true

# Local OpenAI-compatible LLM endpoint.
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=

# Runtime data.
DATA_DIR=./data
TIMEZONE=Asia/Shanghai

# Conservative platform-safety mode for small internal verification.
# Keep SAFETY_MODE=true before public launch.
SAFETY_MODE=true
SAFETY_REQUIRE_OPENID_WHITELIST=true
# Comma-separated OpenIDs allowed to use the assistant, e.g. openid1,openid2
SAFETY_ALLOWED_OPENIDS=
# Required for /ops/safety/users and H5 settings APIs.
SAFETY_ADMIN_TOKEN=change-this-long-random-token
SAFETY_MAX_TEXT_CHARS=800
SAFETY_MAX_MESSAGES_PER_MINUTE=3
SAFETY_MAX_MESSAGES_PER_DAY=20
SAFETY_REPLY_PREFIX=[AI助手] 
SAFETY_ALLOW_MEMORY=true
SAFETY_ALLOW_TASK_CREATION=false
SAFETY_ALLOW_PROACTIVE_TASK_SEND=false
WECHAT_MAX_REPLY_CHUNKS=1
